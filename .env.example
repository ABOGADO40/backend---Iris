# ==============================================================================
# SISTEMA IRIS - Variables de Entorno (PLANTILLA)
# ==============================================================================
#
# 📌 INSTRUCCIONES:
#   1. Copia este archivo como ".env" para desarrollo LOCAL
#   2. Completa los valores según tu instalación local
#   3. NUNCA subas el archivo .env al repositorio (está en .gitignore)
#
# ⚠️  Para RAILWAY (producción):
#     Las variables se configuran directamente en el dashboard de Railway,
#     NO en este archivo. Ver ".env.railway.example" para referencia.
#
# ==============================================================================

# Base de datos LOCAL (PostgreSQL en tu máquina)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://postgres:tu_contraseña@localhost:5432/iris_peritajes?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
JWT_EXPIRES_IN="24h"

# Servidor LOCAL
PORT=3001
NODE_ENV=development

# AI Configuration Encryption Key
# IMPORTANTE: Esta clave se usa para encriptar las API Keys de IA en la base de datos
# Debe ser una cadena segura de al menos 32 caracteres
AI_ENCRYPTION_KEY="your-secure-encryption-key-minimum-32-chars"

# Upload Configuration
MAX_FILE_SIZE=2147483648
UPLOAD_PATH=./uploads

# Frontend URL (CORS) - Para desarrollo local
FRONTEND_URL=http://localhost:5173

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password-16-chars
EMAIL_FROM="Sistema IRIS <tu-correo@gmail.com>"
