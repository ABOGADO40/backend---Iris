# ==============================================================================
# SISTEMA IRIS - Variables de Entorno para RAILWAY (Producción)
# ==============================================================================
#
# ⚠️  IMPORTANTE: Este archivo es solo una REFERENCIA.
#     NO se usa directamente. Las variables se configuran en el dashboard de Railway:
#     https://railway.app → Proyecto → Service → Variables
#
# 📌 Railway asigna automáticamente:
#     - PORT: Puerto del servidor (no configurar manualmente)
#     - DATABASE_URL: Si usas el servicio de PostgreSQL de Railway
#
# ⚠️  NUNCA copies las credenciales de Railway a tu .env local.
#     Las bases de datos LOCAL y RAILWAY son INDEPENDIENTES.
#
# ==============================================================================

# Base de datos Railway (proporcionada automáticamente por Railway PostgreSQL)
# DATABASE_URL=postgresql://postgres:****@*****.proxy.rlwy.net:*****/railway

# NODE_ENV debe ser "production" en Railway
NODE_ENV=production

# JWT Configuration (usar un secreto diferente al de desarrollo)
JWT_SECRET="un-secreto-jwt-muy-seguro-y-diferente-al-de-desarrollo"
JWT_EXPIRES_IN="24h"

# Clave de encriptación (usar una clave diferente a la de desarrollo)
AI_ENCRYPTION_KEY="clave-encriptacion-produccion-diferente-32chars!"

# Upload Configuration
MAX_FILE_SIZE=2147483648
UPLOAD_PATH=./uploads

# Frontend URL (CORS) - URL del frontend desplegado en Railway/Vercel/etc.
FRONTEND_URL=https://tu-frontend-desplegado.up.railway.app
